---
/* src/components/Header.astro */
---
<header>
  <div class="container">
    <nav>
      <a href="/" class="logo">Momiji's Blog</a>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/about">About</a></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  header {
    height: var(--nav-height);
    border-bottom: 1px solid var(--color-border);
  }
  .container {
    height: 100%;
    max-width: none;
    padding-left: 2rem;
    padding-right: 8rem; /* メニューを内側に寄せる */
  }
  nav {
    height: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .logo {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--color-text);
    text-decoration: none;
  }
  ul {
    display: flex;
    list-style: none;
    gap: 1.5rem;
    margin: 0;
    padding: 0;
  }
  a {
    color: var(--color-text);
    font-weight: 500;
  }
  a:hover {
    color: var(--color-accent);
  }
</style>
