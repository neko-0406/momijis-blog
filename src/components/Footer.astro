---
/* src/components/Footer.astro */
const year = new Date().getFullYear();
---
<footer>
  <div class="container">
    <p>&copy; {year} Momiji's Blog. Built with Astro & Bun.</p>
  </div>
</footer>

<style>
  footer {
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
    margin-top: auto;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
</style>
